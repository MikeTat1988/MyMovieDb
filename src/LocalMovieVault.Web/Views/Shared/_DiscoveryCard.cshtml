@using LocalMovieVault.Web.Helpers
@using LocalMovieVault.Web.Models
@model Movie
@{
    var score = RecommendationViewHelper.GetDisplayMatchScore(Model);
    var dismissThreshold = ViewData["DismissScoreThreshold"] is decimal threshold ? threshold : 50m;
    var detailUrl = Url.Action("Details", "Movies", new { id = Model.Id }) ?? "#";
    var reviewReturnUrl = detailUrl;
    var reviewTabUrl = Url.Action("Index", "Movies", new { section = "review" }) ?? "/Movies?section=review";
    var trailerQuery = string.IsNullOrWhiteSpace(Model.Title)
        ? string.Empty
        : $"{Model.Title}{(Model.Year.HasValue ? $" {Model.Year.Value}" : string.Empty)} trailer";
    var trailerUrl = string.IsNullOrWhiteSpace(trailerQuery)
        ? "https://www.youtube.com"
        : $"https://www.youtube.com/results?search_query={System.Net.WebUtility.UrlEncode(trailerQuery)}";
    var isWatched = Model.WatchedStatus == WatchedStatus.Watched;
    var isDismissed = Model.IsDismissed;
    var isDismissSuggested = MovieStateHelper.IsDismissSuggested(Model, dismissThreshold);
    var hasCompletedReview = RecommendationViewHelper.HasCompletedReview(Model);
    var watchActionReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var primaryGenre = RecommendationViewHelper.SplitCsv(Model.GenresCsv).FirstOrDefault() ?? "No genre";
    var metaLine = Model.Year.HasValue ? $"{primaryGenre} • {Model.Year.Value}" : primaryGenre;
    var showUserScore = isWatched
        && !Model.NeedsTagReview
        && Model.UserRating.HasValue
        && Model.UserGrade.HasValue;
    var reviewActionLabel = isDismissed
        ? "View details"
        : !isWatched
            ? "Review"
            : hasCompletedReview
                ? "Edit review"
                : "Finish review";
    var cardStateLabel = isDismissed
        ? "Dismissed"
        : isDismissSuggested
            ? "Suggested dismiss"
            : !isWatched
                ? "Queued"
                : hasCompletedReview
                    ? "Ready"
                    : "Review later";
    var fitLabel = score switch
    {
        >= 82m => "Strong fit",
        >= 68m => "Good fit",
        >= 52m => "Mixed fit",
        >= 36m => "Risky fit",
        _ => "Weak fit"
    };
    var watchToggleClass = isWatched ? "movie-card-status-toggle is-watched js-toggle-unwatched" : "movie-card-status-toggle is-unwatched js-open-watch-modal";
    var watchToggleLabel = isWatched ? "Mark unwatched" : "Mark watched or review later";
    var dismissToggleClass = isDismissed
        ? "movie-card-dismiss-toggle is-dismissed js-toggle-dismiss-state"
        : isDismissSuggested
            ? "movie-card-dismiss-toggle is-suggested js-toggle-dismiss-state"
            : "movie-card-dismiss-toggle is-hidden";
    var dismissToggleLabel = isDismissed ? "Restore dismissed movie" : isDismissSuggested ? "Dismiss movie" : "Dismiss unavailable";
    var wowToggleLabel = Model.IsWowPick ? "Remove wow pick" : "Mark as wow pick";
}

<article class="movie-card discovery-card"
         data-movie-card
         data-movie-id="@Model.Id"
         data-title="@Model.Title"
         data-genre="@Model.GenresCsv"
         data-watched="@(isWatched ? "watched" : "unwatched")"
         data-primary-verdict="@(Model.PrimaryVerdict?.ToString() ?? string.Empty)"
         data-reason-tags="@RecommendationViewHelper.JoinCsv(RecommendationViewHelper.SplitCsv(Model.NormalizedTagsCsv ?? Model.ReasonTagsCsv))">
    <div class="movie-card-media">
        <button class="@dismissToggleClass"
                type="button"
                aria-label="@dismissToggleLabel"
                title="@dismissToggleLabel"
                data-movie-id="@Model.Id"
                data-movie-title="@Model.Title"
                data-return-url="@watchActionReturnUrl"
                data-dismissed="@(isDismissed ? "true" : "false")"
                disabled="@(!isDismissed && !isDismissSuggested)">
            <span aria-hidden="true">X</span>
        </button>
        <a class="movie-card-poster-link" href="@detailUrl">
            @if (!string.IsNullOrWhiteSpace(Model.PosterUrl))
            {
                <img class="movie-thumb" src="@Model.PosterUrl" alt="Poster for @Model.Title" loading="lazy" />
            }
            else
            {
                <div class="movie-thumb placeholder">
                    <div class="placeholder-title">@Model.Title</div>
                    <div class="placeholder-year">@(Model.Year?.ToString() ?? "Unknown year")</div>
                </div>
            }
        </a>
        <button class="@watchToggleClass"
                type="button"
                aria-label="@watchToggleLabel"
                title="@watchToggleLabel"
                data-movie-id="@Model.Id"
                data-movie-title="@Model.Title"
                data-movie-genre="@Model.GenresCsv"
                data-movie-genre-display="@primaryGenre"
                data-primary-verdict="@(Model.PrimaryVerdict?.ToString() ?? string.Empty)"
                data-reason-tags="@RecommendationViewHelper.JoinCsv(RecommendationViewHelper.SplitCsv(Model.NormalizedTagsCsv ?? Model.ReasonTagsCsv))"
                data-return-url="@watchActionReturnUrl"
                data-review-tab-url="@reviewTabUrl"
                data-watched="@(isWatched ? "watched" : "unwatched")">
            <span aria-hidden="true">V</span>
        </button>
    </div>

    <div class="movie-card-body compact-body">
        <div class="movie-card-eyebrow">@cardStateLabel</div>
        @if (Model.IsWowPick)
        {
            <div class="movie-card-eyebrow">Wow pick</div>
        }
        <div class="movie-card-title-frame">
            <h3 class="movie-card-title">
                <a class="movie-card-title-link" href="@detailUrl">@Model.Title</a>
            </h3>
        </div>

        <div class="movie-card-meta-line">@metaLine</div>

        <div class="movie-card-score-line">
            <span class="movie-card-score-chip movie-card-score-chip--accent">
                <span class="movie-card-score-chip-label">Match</span>
                <span class="movie-card-score-chip-value">@score.ToString("0.#")</span>
            </span>
            <span class="movie-card-score-chip">
                <span class="movie-card-score-chip-label">IMDb</span>
                <span class="movie-card-score-chip-value">@(Model.ImdbRating?.ToString("0.0") ?? "-")</span>
            </span>
            <span class="movie-card-score-chip movie-card-score-chip--fit">
                <span class="movie-card-score-chip-label">Fit</span>
                <span class="movie-card-score-chip-value">@fitLabel</span>
            </span>
            @if (showUserScore)
            {
                <span class="movie-card-score-chip movie-card-score-chip--user movie-card-score-chip--user-inline">
                    <span class="movie-card-score-chip-label">You</span>
                    <span class="movie-card-score-chip-value">@Model.UserRating?.ToString("0.#")</span>
                </span>
            }
        </div>

        <div class="card-actions compact-card-actions movie-card-actions">
            <div class="movie-card-action-group">
                @if (isWatched && hasCompletedReview)
                {
                    <button class="button small @(Model.IsWowPick ? "primary" : "subtle") js-toggle-wow-state"
                            type="button"
                            title="@wowToggleLabel"
                            data-movie-id="@Model.Id"
                            data-movie-title="@Model.Title"
                            data-return-url="@watchActionReturnUrl"
                            data-wow="@(Model.IsWowPick ? "true" : "false")">
                        @(Model.IsWowPick ? "Wow" : "Mark wow")
                    </button>
                }
                @if (isDismissed)
                {
                    <button class="button small js-toggle-dismiss-state"
                            type="button"
                            data-movie-id="@Model.Id"
                            data-movie-title="@Model.Title"
                            data-return-url="@watchActionReturnUrl"
                            data-dismissed="true">Restore</button>
                }
                else
                {
                    <a class="button small js-open-watch-modal"
                       href="@detailUrl"
                       data-movie-id="@Model.Id"
                       data-movie-title="@Model.Title"
                       data-movie-genre="@Model.GenresCsv"
                       data-movie-genre-display="@primaryGenre"
                       data-primary-verdict="@(Model.PrimaryVerdict?.ToString() ?? string.Empty)"
                       data-reason-tags="@RecommendationViewHelper.JoinCsv(RecommendationViewHelper.SplitCsv(Model.NormalizedTagsCsv ?? Model.ReasonTagsCsv))"
                       data-return-url="@reviewReturnUrl"
                       data-review-tab-url="@reviewTabUrl"
                       data-watched="@(isWatched ? "watched" : "unwatched")">@reviewActionLabel</a>
                }
                <a class="button small" href="@trailerUrl" target="_blank" rel="noopener">Trailer</a>
            </div>
        </div>
    </div>
</article>
