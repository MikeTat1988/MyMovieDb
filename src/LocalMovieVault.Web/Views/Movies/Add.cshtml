@using LocalMovieVault.Web.Models
@model AddMoviePageViewModel
@{
    ViewData["Title"] = "Add";
    var currentYear = DateTime.UtcNow.Year + 1;
}

<section class="panel add-shell add-hero-shell">
    <div class="panel-header compact-header-gap">
        <div>
            <div class="eyebrow">Lookup by online metadata</div>
            <h1>Add movie</h1>
            <div class="panel-subtitle">Search the full catalog, pick the right match, preview the fit, then add it to your library.</div>
        </div>
    </div>

    <form asp-action="Lookup" method="post" class="lookup-form-simple add-search-form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert error"></div>
        <div class="lookup-fields-row">
            <div class="lookup-title-field">
                <label asp-for="LookupTitle">Title</label>
                <input asp-for="LookupTitle" placeholder="For example: Pandorum" />
            </div>
            <div class="lookup-year-field">
                <label asp-for="LookupYear">Year</label>
                <select asp-for="LookupYear">
                    <option value="">Any</option>
                    @for (var year = currentYear; year >= 1900; year--)
                    {
                        <option value="@year" selected="@(Model.LookupYear == year)">@year</option>
                    }
                </select>
            </div>
            <div class="lookup-submit-field">
                <button class="button primary lookup-submit" type="submit">Search</button>
            </div>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.LookupMessage))
    {
        <div class="alert @(Model.ShowSavePopup ? "success" : "info") add-inline-message">@Model.LookupMessage</div>
    }
</section>

@if (Model.ShowSavePopup)
{
    <section class="panel add-result-shell" id="addSelectedMovie">
        <div class="panel-header compact-header-gap">
            <div>
                <div class="eyebrow">Selected match</div>
                <h2>Ready to add</h2>
                <div class="panel-subtitle">Preview the recommendation first if you want, then add it directly to Library.</div>
            </div>
        </div>

        <div class="add-result-grid add-result-grid-featured">
            <div class="add-poster-col">
                @if (!string.IsNullOrWhiteSpace(Model.Movie.PosterUrl))
                {
                    <img class="lookup-poster" src="@Model.Movie.PosterUrl" alt="Poster for @Model.Movie.Title" />
                }
                else
                {
                    <div class="lookup-poster placeholder">
                        <div class="placeholder-title">@Model.Movie.Title</div>
                        @if (Model.Movie.Year.HasValue)
                        {
                            <div class="placeholder-year">@Model.Movie.Year</div>
                        }
                    </div>
                }
            </div>

            <div class="add-main-col">
                <div class="add-summary add-summary-hero">
                    <div class="add-summary-title">@Model.Movie.Title</div>
                    <div class="add-summary-meta">
                        <span>@(Model.Movie.Year?.ToString() ?? "-")</span>
                        <span>@Model.Movie.MediaType</span>
                        @if (!string.IsNullOrWhiteSpace(Model.Movie.GenresCsv))
                        {
                            <span>@Model.Movie.GenresCsv</span>
                        }
                    </div>
                    <div class="metric-row">
                        <span class="metric-chip">IMDb @(Model.Movie.ImdbRating?.ToString("0.0") ?? "-")</span>
                        @if (Model.Movie.ImdbVotes.HasValue)
                        {
                            <span class="metric-chip">@Model.Movie.ImdbVotes.Value.ToString("N0") votes</span>
                        }
                        @if (Model.Movie.RuntimeMinutes.HasValue)
                        {
                            <span class="metric-chip">@Model.Movie.RuntimeMinutes min</span>
                        }
                    </div>
                </div>

                <form asp-action="Create" method="post" class="save-form-simple add-save-form" id="addMovieSaveForm" data-add-movie-form="true">
                    @Html.AntiForgeryToken()
                    <input asp-for="Movie.Category" type="hidden" />
                    <input asp-for="Movie.ImdbRating" type="hidden" />
                    <input asp-for="Movie.ImdbVotes" type="hidden" />
                    <input asp-for="Movie.RuntimeMinutes" type="hidden" />
                    <input asp-for="Movie.Country" type="hidden" />
                    <input asp-for="Movie.Language" type="hidden" />
                    <input asp-for="Movie.PosterUrl" type="hidden" />
                    <input asp-for="Movie.Overview" type="hidden" />
                    <input asp-for="Movie.Director" type="hidden" />
                    <input asp-for="Movie.Writer" type="hidden" />
                    <input asp-for="Movie.Actors" type="hidden" />
                    <input asp-for="Movie.Metascore" type="hidden" />
                    <input asp-for="Movie.ReleasedOn" type="hidden" />
                    <input asp-for="Movie.ExternalSource" type="hidden" />
                    <input asp-for="Movie.ExternalId" type="hidden" />
                    <input asp-for="Movie.OmdbType" type="hidden" />
                    <input asp-for="Movie.OmdbRatingsJson" type="hidden" />
                    <input asp-for="Movie.TmdbId" type="hidden" />
                    <input asp-for="Movie.TmdbKeywordsCsv" type="hidden" />
                    <input asp-for="Movie.SimilarTitlesJson" type="hidden" />
                    <input asp-for="Movie.ExternalRatingsJson" type="hidden" />
                    <input asp-for="LookupTitle" type="hidden" />
                    <input asp-for="LookupYear" type="hidden" />
                    <input asp-for="SelectedImdbId" type="hidden" />
                    <input asp-for="ShowSavePopup" type="hidden" value="true" />
                    <input type="hidden" name="addVerdict" id="addMovieVerdict" />
                    <input type="hidden" name="queueForReview" id="addMovieQueueForReview" value="false" />
                    <div id="addMovieReasonTagsContainer"></div>

                    <div asp-validation-summary="ModelOnly" class="alert error"></div>

                    <div class="simple-save-controls">
                        <div>
                            <label>Library state</label>
                            <div class="segmented-control segmented-control-tight segmented-control-wrap" data-segmented-control>
                                <label class="segment-button @(Model.Movie.WatchedStatus == WatchedStatus.Watched ? "is-active" : string.Empty)">
                                    <input id="addMovieWatched" type="radio" asp-for="Movie.WatchedStatus" value="@WatchedStatus.Watched" />
                                    Watched
                                </label>
                                <label class="segment-button @(Model.Movie.WatchedStatus != WatchedStatus.Watched ? "is-active" : string.Empty)">
                                    <input id="addMovieNotWatched" type="radio" asp-for="Movie.WatchedStatus" value="@WatchedStatus.NotWatched" />
                                    Not watched
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="field-help">
                        Choose <strong>Watched</strong> to open the review popup and save your verdict before the movie is added.
                    </div>

                    <details class="advanced-box">
                        <summary>Advanced</summary>
                        <div class="advanced-grid">
                            <div>
                                <label asp-for="Movie.Title"></label>
                                <input asp-for="Movie.Title" />
                            </div>
                            <div>
                                <label asp-for="Movie.OriginalTitle"></label>
                                <input asp-for="Movie.OriginalTitle" />
                            </div>
                            <div>
                                <label asp-for="Movie.Year"></label>
                                <input asp-for="Movie.Year" />
                            </div>
                            <div>
                                <label asp-for="Movie.MediaType"></label>
                                <select asp-for="Movie.MediaType" asp-items="Html.GetEnumSelectList<MediaType>()"></select>
                            </div>
                            <div class="span-2">
                                <label asp-for="Movie.GenresCsv"></label>
                                <input asp-for="Movie.GenresCsv" />
                            </div>
                            <div class="span-2">
                                <label asp-for="Movie.Notes"></label>
                                <textarea asp-for="Movie.Notes" rows="3"></textarea>
                            </div>
                            <div class="span-2">
                                <label asp-for="Movie.TagsCsv"></label>
                                <input asp-for="Movie.TagsCsv" />
                            </div>
                        </div>
                    </details>

                    <div class="toolbar save-actions-row add-actions-row">
                        <button class="button subtle" type="submit" formaction="@Url.Action("PreviewEstimate", "Movies")" data-add-submit-mode="estimate">Estimate match</button>
                        <button class="button primary js-add-movie-submit" type="submit" data-add-submit-mode="add">Add to library</button>
                        <a class="button" asp-action="Add">Reset</a>
                    </div>
                </form>
            </div>
        </div>
    </section>
}

@if (Model.Candidates.Count > 1)
{
    <section class="panel add-choice-shell">
        <div class="panel-header compact-header-gap">
            <div>
                <div class="eyebrow">Top matches</div>
                <h2>Pick from the top 10</h2>
                <div class="panel-subtitle">Ranked from the strongest exact match, then by IMDb vote count.</div>
            </div>
        </div>
        <div class="choice-grid">
            @foreach (var candidate in Model.Candidates)
            {
                <article class="choice-card @(candidate.ImdbId == Model.SelectedImdbId ? "is-selected" : string.Empty)">
                    <div class="choice-poster-wrap">
                        @if (!string.IsNullOrWhiteSpace(candidate.PosterUrl))
                        {
                            <img class="choice-poster" src="@candidate.PosterUrl" alt="Poster for @candidate.Title" />
                        }
                        else
                        {
                            <div class="choice-poster placeholder">
                                <div class="placeholder-title">@candidate.Title</div>
                            </div>
                        }
                    </div>
                    <div class="choice-body">
                        <div class="choice-title">@candidate.Title</div>
                        <div class="choice-meta">
                            <span>@(candidate.Year?.ToString() ?? "-")</span>
                            <span>@candidate.MediaType</span>
                            @if (!string.IsNullOrWhiteSpace(candidate.GenresCsv))
                            {
                                <span>@candidate.GenresCsv</span>
                            }
                        </div>
                        <div class="metric-row compact-metrics">
                            <span class="metric-chip">IMDb @(candidate.ImdbRating?.ToString("0.0") ?? "-")</span>
                            @if (candidate.ImdbVotes.HasValue)
                            {
                                <span class="metric-chip">@candidate.ImdbVotes.Value.ToString("N0") votes</span>
                            }
                            @if (candidate.RuntimeMinutes.HasValue)
                            {
                                <span class="metric-chip">@candidate.RuntimeMinutes min</span>
                            }
                        </div>
                    </div>
                    <form asp-action="ChooseCandidate" method="post" class="choice-select-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="imdbId" value="@candidate.ImdbId" />
                        <input type="hidden" name="lookupTitle" value="@Model.LookupTitle" />
                        <input type="hidden" name="lookupYear" value="@Model.LookupYear" />
                        <button class="button small @(candidate.ImdbId == Model.SelectedImdbId ? "primary" : string.Empty)" type="submit">
                            @(candidate.ImdbId == Model.SelectedImdbId ? "Selected match" : "Use this match")
                        </button>
                    </form>
                </article>
            }
        </div>
    </section>
}

<partial name="_WatchFeedbackModal" />

@if (Model.EstimatePreview is not null)
{
    <partial name="_EstimatePreviewModal" model="Model" />
}
